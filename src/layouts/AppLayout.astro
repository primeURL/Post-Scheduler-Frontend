---
import { ClientRouter } from "astro:transitions";
import Sidebar from "../components/Sidebar";
import HeaderUser from "../components/HeaderUser";
import PageTitle from "../components/PageTitle";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Post Scheduler",
  description = "Schedule your X posts with precision.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Martian+Mono:wght@300;400;500&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --color-ink:      #0A0C10;
        --color-surface:  #11141C;
        --color-elevated: #1A1D28;
        --color-border:   #252B3C;
        --color-cream:    #DED9CE;
        --color-muted:    #545B73;
        --color-accent:   #8B97FF;
        --color-amber:    #F0A850;
        --color-danger:   #F07050;
        --color-success:  #4ECC80;
        --font-sans: "Syne", system-ui, sans-serif;
        --font-mono: "Martian Mono", monospace;
      }

      body.app {
        background-color: var(--color-ink);
        color: var(--color-cream);
        font-family: var(--font-sans);
        margin: 0;
        padding: 0;
      }

      /* View transition fixes for React components */
      [transition\:persist] {
        overflow: visible !important;
      }
      
      .analytics-post-card {
        display: grid !important;
      }

      /* ── Analytics Post Status Chips (Fixed for Navigation) ── */
      .post-status-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 10px;
        border-radius: 8px;
        font-family: var(--font-mono);
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        white-space: nowrap;
      }

      .post-status-badge--published {
        color: var(--color-success);
        border: 1px solid color-mix(in srgb, var(--color-success) 40%, transparent);
        background: color-mix(in srgb, var(--color-success) 10%, transparent);
      }

      .post-status-badge--scheduled {
        color: var(--color-accent);
        border: 1px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
        background: color-mix(in srgb, var(--color-accent) 10%, transparent);
      }

      .post-status-badge--draft {
        color: var(--color-amber);
        border: 1px solid color-mix(in srgb, var(--color-amber) 40%, transparent);
        background: color-mix(in srgb, var(--color-amber) 10%, transparent);
      }

      .post-status-badge--deleted {
        color: var(--color-danger);
        border: 1px solid color-mix(in srgb, var(--color-danger) 40%, transparent);
        background: color-mix(in srgb, var(--color-danger) 10%, transparent);
      }

      /* Analytics Metrics & Tabs (Stability Injection) */
      .analytics-metric-card {
        position: relative;
        border: 1px solid var(--color-border);
        border-radius: 16px;
        overflow: hidden;
        background: linear-gradient(145deg, color-mix(in srgb, var(--color-elevated) 96%, transparent), color-mix(in srgb, var(--color-ink) 30%, transparent));
        transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
      }

      .analytics-tab-bar {
        display: flex;
        align-items: center;
        gap: 2px;
        background: color-mix(in srgb, var(--color-ink) 40%, transparent);
        border: 1px solid var(--color-border);
        border-radius: 14px;
        padding: 4px;
      }

      .analytics-tab {
        position: relative;
        border-radius: 10px;
        border: none;
        background: transparent;
        color: var(--color-muted);
        padding: 10px 18px;
        font-size: 12px;
        font-family: var(--font-mono);
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        cursor: pointer;
        transition: color 0.2s ease, background 0.2s ease;
      }

      /* Transitions */
      @keyframes slideInRow {
        from { opacity: 0; transform: translateX(-12px); }
        to { opacity: 1; transform: translateX(0); }
      }
    </style>
  </head>
  <body class="app">
    <div class="flex h-screen overflow-hidden">

      <!-- Collapsible sidebar -->
      <Sidebar client:only="react" transition:persist />

      <!-- Right: header + scrollable content -->
      <div class="flex flex-col flex-1 min-w-0 overflow-hidden">

        <!-- Top header -->
        <header class="flex items-center justify-between border-b border-border bg-surface px-6 shrink-0" style="height: 56px;">

          <!-- Page title — replaces the search bar -->
          <PageTitle client:only="react" transition:persist />

          <!-- Right actions -->
          <div class="flex items-center gap-3">
            <button
              class="flex size-9 items-center justify-center rounded-lg border border-border bg-elevated text-muted hover:text-cream hover:border-accent/40 transition-colors"
              title="Notifications"
            >
              <span class="material-symbols-outlined" style="font-size:20px;">notifications</span>
            </button>
            <button
              class="flex size-9 items-center justify-center rounded-lg border border-border bg-elevated text-muted hover:text-cream hover:border-accent/40 transition-colors"
              title="Settings"
            >
              <span class="material-symbols-outlined" style="font-size:20px;">settings</span>
            </button>
            <HeaderUser client:only="react" />
          </div>

        </header>

        <!-- Page content -->
        <main class="flex-1 overflow-y-auto">
          <slot />
        </main>

      </div>
    </div>
  </body>
</html>
