---
import LandingLayout from "../layouts/LandingLayout.astro";
---

<LandingLayout
  title="Post Scheduler — Master Your Social Presence"
  description="X-first social media scheduling for modern creators. Build, schedule, and track X threads with cinematic precision and deep analytics."
>
  <!-- ── Inline theme-toggle script ── -->
  <script is:inline>
    function toggleTheme() {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("ps-theme", isDark ? "dark" : "light");
      document.querySelectorAll(".theme-icon").forEach(function (el) {
        el.textContent = isDark ? "light_mode" : "dark_mode";
      });
    }
    function toggleMobileMenu() {
      document.getElementById("mobile-menu").classList.toggle("hidden");
    }
  </script>

  <div class="relative min-h-screen overflow-x-hidden">
    <!-- Ambient background -->
    <div class="absolute inset-0 landing-grid-bg pointer-events-none opacity-50" aria-hidden="true"></div>
    <div
      class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[800px] h-[600px] rounded-full pointer-events-none"
      style="background:rgba(123,97,255,0.18);filter:blur(120px);"
      aria-hidden="true"
    ></div>

    <!-- ── NAV ── -->
    <nav
      class="relative z-50 border-b border-slate-200 dark:border-slate-800 backdrop-blur-md sticky top-0 bg-white/80 dark:bg-background-dark/80"
      aria-label="Main navigation"
    >
      <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3" aria-label="Post Scheduler home">
          <div class="bg-primary p-1.5 rounded-lg">
            <span class="material-symbols-outlined text-white text-2xl" aria-hidden="true">grid_view</span>
          </div>
          <span class="text-xl font-bold tracking-tight">Post Scheduler</span>
        </a>

        <!-- Desktop links -->
        <div class="hidden md:flex items-center gap-10">
          <a class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary transition-colors" href="#features">Features</a>
          <a class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary transition-colors" href="#analytics">Analytics</a>
          <a class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary transition-colors" href="/login">Login</a>

          <!-- Theme toggle -->
          <button
            onclick="toggleTheme()"
            class="p-2 rounded-lg text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
            aria-label="Toggle dark/light mode"
          >
            <span class="material-symbols-outlined theme-icon text-xl">dark_mode</span>
          </button>

          <a
            href="/dashboard"
            class="bg-primary hover:bg-primary/90 text-white px-6 py-2.5 rounded-lg text-sm font-bold transition-all hover:scale-105 inline-block"
          >
            Get Started
          </a>
        </div>

        <!-- Mobile controls -->
        <div class="md:hidden flex items-center gap-2">
          <button
            onclick="toggleTheme()"
            class="p-2 rounded-lg text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
            aria-label="Toggle dark/light mode"
          >
            <span class="material-symbols-outlined theme-icon text-xl">dark_mode</span>
          </button>
          <button
            onclick="toggleMobileMenu()"
            class="p-2 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors"
            aria-label="Open menu"
          >
            <span class="material-symbols-outlined">menu</span>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200 dark:border-slate-800 px-6 py-4 flex flex-col gap-4 bg-white/95 dark:bg-background-dark/95 backdrop-blur">
        <a class="text-sm font-medium text-slate-700 dark:text-slate-300" href="#features">Features</a>
        <a class="text-sm font-medium text-slate-700 dark:text-slate-300" href="#analytics">Analytics</a>
        <a class="text-sm font-medium text-slate-700 dark:text-slate-300" href="/login">Login</a>
        <a href="/dashboard" class="bg-primary text-white px-6 py-3 rounded-lg text-sm font-bold text-center">Get Started</a>
      </div>
    </nav>

    <main>
      <!-- ── HERO ── -->
      <section class="relative pt-16 pb-28 px-6" aria-labelledby="hero-heading">
        <div class="max-w-7xl mx-auto text-center">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 mb-8">
            <span class="relative flex h-2 w-2" aria-hidden="true">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
            </span>
            <span class="text-xs font-bold tracking-widest uppercase text-primary">Now supporting X threads</span>
          </div>

          <h1 id="hero-heading" class="text-5xl md:text-8xl font-black tracking-tight mb-8 leading-[1.1]">
            Master your <br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-indigo-400">social presence.</span>
          </h1>

          <p class="max-w-2xl mx-auto text-lg md:text-xl text-slate-500 dark:text-slate-400 font-light leading-relaxed mb-12">
            X-first scheduling for modern creators. Build your audience with cinematic precision
            and an atmospheric workflow designed for high-impact editorial storytelling.
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-20">
            <a
              href="/dashboard"
              class="w-full sm:w-auto px-8 py-4 bg-primary text-white font-bold rounded-xl text-lg hover:shadow-lg transition-all"
              style="box-shadow:none;"
              onmouseover="this.style.boxShadow='0 10px 40px -5px rgba(123,97,255,0.4)'"
              onmouseout="this.style.boxShadow='none'"
            >
              Start for Free
            </a>
            <a
              href="#features"
              class="w-full sm:w-auto px-8 py-4 bg-slate-100 dark:bg-slate-800/50 backdrop-blur border border-slate-200 dark:border-slate-700 text-slate-800 dark:text-white font-bold rounded-xl text-lg hover:bg-slate-200 dark:hover:bg-slate-700 transition-all text-center"
            >
              See Features
            </a>
          </div>

          <!-- App Preview Mockup -->
          <div class="relative mx-auto max-w-5xl group">
            <div
              class="absolute -inset-1 rounded-xl blur-2xl opacity-30 group-hover:opacity-50 transition duration-1000 pointer-events-none"
              style="background:linear-gradient(to right,rgba(123,97,255,0.5),rgba(99,102,241,0.5));"
              aria-hidden="true"
            ></div>
            <div class="relative bg-slate-900 border border-slate-700/50 rounded-xl overflow-hidden shadow-2xl glow-effect" role="img" aria-label="Post Scheduler dashboard preview">
              <!-- Window chrome -->
              <div class="h-10 bg-slate-950 border-b border-slate-800 flex items-center px-4 gap-2">
                <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
                <span class="ml-3 text-xs text-slate-500 font-mono">Post Scheduler — Compose</span>
              </div>
              <!-- Mock UI -->
              <div class="flex min-h-64">
                <!-- Sidebar -->
                <div class="w-14 lg:w-48 bg-slate-950/50 border-r border-slate-800 p-3 flex flex-col gap-2 shrink-0">
                  <div class="h-7 bg-primary/20 rounded-lg flex items-center px-2 gap-2">
                    <div class="w-2 h-2 rounded-full bg-primary shrink-0"></div>
                    <div class="hidden lg:block h-2 bg-primary/40 rounded w-full"></div>
                  </div>
                  {[1,2,3,4].map(() => (
                    <div class="h-7 bg-slate-800/60 rounded-lg flex items-center px-2 gap-2">
                      <div class="w-2 h-2 rounded-full bg-slate-600 shrink-0"></div>
                      <div class="hidden lg:block h-2 bg-slate-700 rounded w-3/4"></div>
                    </div>
                  ))}
                </div>
                <!-- Main panel -->
                <div class="flex-1 p-6 space-y-4 bg-slate-900">
                  <!-- Composer area -->
                  <div class="bg-slate-800/50 rounded-xl border border-slate-700/50 p-4 space-y-3">
                    <div class="h-3 bg-slate-600 rounded w-1/3"></div>
                    <div class="h-16 bg-slate-700/40 rounded-lg"></div>
                    <div class="flex gap-2">
                      <div class="h-7 w-16 bg-primary rounded-lg"></div>
                      <div class="h-7 w-20 bg-slate-700 rounded-lg"></div>
                    </div>
                  </div>
                  <!-- Scheduled cards row -->
                  <div class="grid grid-cols-3 gap-3">
                    {[
                      { w: "w-full", accent: true },
                      { w: "w-3/4", accent: false },
                      { w: "w-1/2", accent: false },
                    ].map(({ w, accent }) => (
                      <div class={`rounded-lg p-3 space-y-2 border ${accent ? "bg-primary/10 border-primary/20" : "bg-slate-800/40 border-slate-700/30"}`}>
                        <div class={`h-2 rounded ${accent ? "bg-primary/50" : "bg-slate-600"} ${w}`}></div>
                        <div class="h-2 bg-slate-700 rounded w-full"></div>
                        <div class="h-2 bg-slate-700 rounded w-2/3"></div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ── THREAD BUILDER ── -->
      <section id="features" class="py-24 px-6 border-t border-slate-200 dark:border-slate-800" aria-labelledby="threads-heading">
        <div class="max-w-7xl mx-auto">
          <div class="grid md:grid-cols-2 gap-20 items-center">
            <div>
              <div class="bg-primary/20 w-12 h-12 rounded-lg flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-primary" aria-hidden="true">auto_awesome</span>
              </div>
              <h2 id="threads-heading" class="text-4xl font-bold mb-6">The Thread Builder</h2>
              <p class="text-slate-500 dark:text-slate-400 text-lg mb-10 leading-relaxed">
                Draft, refine, and visualize your stories before they go live. An editorial
                experience for high-impact content. Split long essays into perfect threads automatically.
              </p>
              <div class="grid gap-6">
                <div class="flex gap-4">
                  <span class="material-symbols-outlined text-primary mt-0.5 shrink-0" aria-hidden="true">drag_indicator</span>
                  <div>
                    <h3 class="font-bold">Drag &amp; Drop Editing</h3>
                    <p class="text-slate-500 dark:text-slate-500 text-sm mt-1">Rearrange your sequence in real-time with visual logic.</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <span class="material-symbols-outlined text-primary mt-0.5 shrink-0" aria-hidden="true">preview</span>
                  <div>
                    <h3 class="font-bold">Live Preview</h3>
                    <p class="text-slate-500 dark:text-slate-500 text-sm mt-1">See exactly how your thread renders on mobile and desktop before posting.</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <span class="material-symbols-outlined text-primary mt-0.5 shrink-0" aria-hidden="true">schedule</span>
                  <div>
                    <h3 class="font-bold">Smart Scheduling</h3>
                    <p class="text-slate-500 dark:text-slate-500 text-sm mt-1">Post at the exact moment your audience is most active.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Feature cards grid -->
            <div class="grid grid-cols-2 gap-4" aria-hidden="true">
              <div class="space-y-4 pt-12">
                <div class="aspect-[4/5] bg-slate-100 dark:bg-slate-800/50 rounded-xl border border-slate-200 dark:border-slate-700/50 p-4 space-y-3">
                  <div class="h-2 bg-slate-300 dark:bg-slate-700 rounded"></div>
                  <div class="h-2 bg-slate-300 dark:bg-slate-700 rounded w-3/4"></div>
                  <div class="h-24 mt-4 bg-slate-200 dark:bg-slate-700/40 rounded-lg"></div>
                  <div class="h-2 bg-slate-300 dark:bg-slate-700 rounded"></div>
                  <div class="h-2 bg-slate-300 dark:bg-slate-700 rounded w-2/3"></div>
                </div>
                <div class="aspect-[4/5] bg-primary/10 rounded-xl border border-primary/20 p-4 space-y-3">
                  <div class="h-2 bg-primary/40 rounded"></div>
                  <div class="h-2 bg-primary/30 rounded w-1/2"></div>
                  <div class="flex gap-2 mt-4">
                    <div class="w-8 h-8 rounded-full bg-primary/40 shrink-0"></div>
                    <div class="flex-1 space-y-2">
                      <div class="h-2 bg-primary/30 rounded"></div>
                      <div class="h-2 bg-primary/30 rounded w-3/4"></div>
                      <div class="h-2 bg-primary/20 rounded w-1/2"></div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="space-y-4">
                <div class="aspect-[4/5] bg-slate-100 dark:bg-slate-800/50 rounded-xl border border-slate-200 dark:border-slate-700/50 p-4 space-y-3">
                  <div class="h-20 bg-slate-200 dark:bg-slate-700/40 rounded-lg"></div>
                  <div class="h-2 bg-slate-300 dark:bg-slate-700 rounded"></div>
                  <div class="h-2 bg-slate-300 dark:bg-slate-700 rounded w-2/3"></div>
                  <div class="h-2 bg-slate-300 dark:bg-slate-700 rounded w-1/2"></div>
                </div>
                <div class="aspect-[4/5] bg-slate-100 dark:bg-slate-800/50 rounded-xl border border-slate-200 dark:border-slate-700/50 p-4 space-y-3">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="material-symbols-outlined text-xs text-primary" style="font-size:14px;">check_circle</span>
                    <span class="text-xs text-slate-500 dark:text-slate-500 font-bold uppercase tracking-wider">Scheduled</span>
                  </div>
                  <div class="h-2 bg-slate-300 dark:bg-slate-700 rounded"></div>
                  <div class="h-2 bg-slate-300 dark:bg-slate-700 rounded"></div>
                  <div class="h-2 bg-slate-300 dark:bg-slate-700 rounded w-1/2"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ── CALENDAR ── -->
      <section class="py-24 px-6 bg-slate-50 dark:bg-slate-900/30" aria-labelledby="calendar-heading">
        <div class="max-w-7xl mx-auto">
          <div class="mb-16">
            <h2 id="calendar-heading" class="text-4xl font-bold mb-4">Visual Calendar</h2>
            <p class="text-slate-500 dark:text-slate-400">Manage your entire content pipeline at a glance.</p>
          </div>

          <div class="flex flex-col lg:flex-row gap-12 items-start">
            <!-- Calendar grid -->
            <div class="flex-1 w-full bg-white dark:bg-background-dark/50 backdrop-blur rounded-2xl border border-slate-200 dark:border-slate-700/50 p-8">
              <div class="flex items-center justify-between mb-8">
                <div class="flex items-center gap-4">
                  <h3 class="text-xl font-bold">March 2026</h3>
                  <div class="flex bg-slate-100 dark:bg-slate-800 rounded-lg p-1">
                    <button class="p-1 hover:bg-slate-200 dark:hover:bg-slate-700 rounded transition-colors" aria-label="Previous month">
                      <span class="material-symbols-outlined text-sm">chevron_left</span>
                    </button>
                    <button class="p-1 hover:bg-slate-200 dark:hover:bg-slate-700 rounded transition-colors" aria-label="Next month">
                      <span class="material-symbols-outlined text-sm">chevron_right</span>
                    </button>
                  </div>
                </div>
                <div class="flex gap-2">
                  <button class="px-3 py-1 bg-primary text-white text-xs font-bold rounded">Month</button>
                  <button class="px-3 py-1 text-xs font-bold text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 rounded transition-colors">Week</button>
                </div>
              </div>

              <div class="grid grid-cols-7 gap-2" role="grid" aria-label="Calendar">
                {["Sun","Mon","Tue","Wed","Thu","Fri","Sat"].map(d => (
                  <div class="text-center text-xs font-bold text-slate-400 pb-3" role="columnheader">{d}</div>
                ))}
                <!-- Empty cells -->
                {[null,null,null,null,null,null].map(() => (
                  <div class="aspect-square bg-slate-50 dark:bg-slate-800/20 rounded-lg border border-slate-100 dark:border-slate-700/20" role="gridcell" aria-label="Empty"></div>
                ))}
                <!-- Days with posts highlighted -->
                {Array.from({length: 16}, (_, i) => i + 1).map(day => {
                  const hasPost = [2, 7, 13, 16].includes(day);
                  const isToday = day === 16;
                  return (
                    <div
                      class={`aspect-square rounded-lg p-2 relative flex flex-col ${
                        hasPost
                          ? "bg-primary/10 border border-primary/30"
                          : isToday
                            ? "bg-slate-100 dark:bg-slate-800/60 border-2 border-primary/50"
                            : "bg-slate-50 dark:bg-slate-800/30 border border-slate-100 dark:border-slate-700/20"
                      }`}
                      role="gridcell"
                      aria-label={`March ${day}${hasPost ? ", has scheduled posts" : ""}`}
                    >
                      <span class="text-xs font-medium">{day}</span>
                      {hasPost && (
                        <div class="absolute bottom-1.5 left-1.5 right-1.5 h-1 bg-primary rounded-full"></div>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>

            <!-- Today's queue -->
            <div class="w-full lg:w-80 space-y-4">
              <div class="p-6 bg-white dark:bg-slate-800/40 rounded-xl border border-slate-200 dark:border-slate-700/50">
                <h4 class="font-bold mb-4">Today's Queue</h4>
                <div class="space-y-3">
                  <div class="flex items-start gap-3 p-3 bg-slate-50 dark:bg-slate-900 rounded-lg">
                    <div class="w-1 bg-primary h-12 rounded-full shrink-0"></div>
                    <div>
                      <p class="text-xs text-slate-400 mb-1">14:00</p>
                      <p class="text-sm font-medium line-clamp-1">Why modern design is shifted...</p>
                    </div>
                  </div>
                  <div class="flex items-start gap-3 p-3 bg-slate-50 dark:bg-slate-900 rounded-lg opacity-50">
                    <div class="w-1 bg-slate-300 dark:bg-slate-700 h-12 rounded-full shrink-0"></div>
                    <div>
                      <p class="text-xs text-slate-400 mb-1">18:30</p>
                      <p class="text-sm font-medium line-clamp-1">10 lessons from the first year...</p>
                    </div>
                  </div>
                </div>
              </div>
              <a
                href="/login"
                class="w-full py-4 border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-xl text-slate-500 font-medium hover:border-primary hover:text-primary transition-all flex items-center justify-center gap-2"
              >
                <span class="material-symbols-outlined text-sm" aria-hidden="true">add</span>
                Schedule Post
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- ── ANALYTICS ── -->
      <section id="analytics" class="py-24 px-6 relative overflow-hidden" aria-labelledby="analytics-heading">
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full pointer-events-none"
          style="background:rgba(123,97,255,0.08);filter:blur(100px);"
          aria-hidden="true"
        ></div>
        <div class="max-w-7xl mx-auto relative">
          <div class="text-center mb-16">
            <h2 id="analytics-heading" class="text-4xl font-bold mb-4">Deep Analytics</h2>
            <p class="text-slate-500 dark:text-slate-400 max-w-xl mx-auto">
              Go beyond vanity metrics. Understand the mechanics of your growth
              with precise data visualizations.
            </p>
          </div>

          <div class="grid md:grid-cols-3 gap-8">
            <!-- Impressions card -->
            <article class="p-8 bg-white dark:bg-slate-800/30 border border-slate-200 dark:border-slate-700/50 rounded-2xl">
              <span class="material-symbols-outlined text-primary mb-4 block" aria-hidden="true">insights</span>
              <h3 class="text-xl font-bold mb-2">Impression Velocity</h3>
              <p class="text-slate-500 text-sm mb-6">Track how fast your threads spread through the network in the first 60 minutes.</p>
              <div class="h-32 bg-slate-100 dark:bg-slate-900/50 rounded-lg flex items-end gap-1 p-3" aria-label="Impressions bar chart">
                {[30, 45, 65, 90, 100, 75, 60].map(h => (
                  <div class="flex-1 rounded-t" style={`height:${h}%;background:${h === 100 ? "rgb(123,97,255)" : "rgba(123,97,255,0.3)"}`}></div>
                ))}
              </div>
            </article>

            <!-- Follower card -->
            <article class="p-8 bg-white dark:bg-slate-800/30 border border-slate-200 dark:border-slate-700/50 rounded-2xl">
              <span class="material-symbols-outlined text-primary mb-4 block" aria-hidden="true">person_add</span>
              <h3 class="text-xl font-bold mb-2">Follower Attribution</h3>
              <p class="text-slate-500 text-sm mb-6">Know exactly which post converted a casual reader into a follower.</p>
              <div class="flex items-center gap-4 pt-4">
                <div
                  class="w-16 h-16 rounded-full shrink-0"
                  style="border:4px solid #7b61ff;border-top-color:transparent;animation:spin 2s linear infinite;"
                  aria-hidden="true"
                ></div>
                <div>
                  <p class="text-2xl font-bold">+1,248</p>
                  <p class="text-xs text-emerald-500 font-bold tracking-wider">▲ 12.4% THIS WEEK</p>
                </div>
              </div>
            </article>

            <!-- Network card -->
            <article class="p-8 bg-white dark:bg-slate-800/30 border border-slate-200 dark:border-slate-700/50 rounded-2xl">
              <span class="material-symbols-outlined text-primary mb-4 block" aria-hidden="true">share</span>
              <h3 class="text-xl font-bold mb-2">Network Influence</h3>
              <p class="text-slate-500 text-sm mb-6">Visualize your reach across different communities and niche circles.</p>
              <!-- Network graph mockup -->
              <div class="h-32 relative" aria-hidden="true">
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="w-8 h-8 rounded-full bg-primary/80 z-10"></div>
                </div>
                {[
                  {top:"10%",left:"15%",size:"w-5 h-5",op:"60"},
                  {top:"60%",left:"10%",size:"w-6 h-6",op:"40"},
                  {top:"15%",left:"70%",size:"w-4 h-4",op:"70"},
                  {top:"65%",left:"72%",size:"w-5 h-5",op:"50"},
                  {top:"35%",left:"5%",size:"w-3 h-3",op:"30"},
                  {top:"30%",left:"82%",size:"w-4 h-4",op:"40"},
                ].map(({top,left,size,op}) => (
                  <div
                    class={`absolute ${size} rounded-full bg-primary`}
                    style={`top:${top};left:${left};opacity:${parseInt(op)/100};`}
                  ></div>
                ))}
              </div>
            </article>
          </div>
        </div>
      </section>

      <!-- ── CTA ── -->
      <section class="py-24 px-6 text-center" aria-labelledby="cta-heading">
        <div
          class="max-w-4xl mx-auto p-12 md:p-16 rounded-[2rem] border border-primary/20 backdrop-blur-sm"
          style="background:linear-gradient(to bottom,rgba(123,97,255,0.12),transparent);"
